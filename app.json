{
  "expo": {
    "name": "dljs",
    "slug": "dljs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/splash-logo.jpeg",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/splash-logo.jpeg"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["RECORD_AUDIO", "RECORD_AUDIO"],
      "package": "com.avinash_kumar.dljs"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-build-properties",
      "expo-font",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "eef752a3-c0ae-4ea0-8b48-530aeb9c8281"
      }
    }
  }
}
